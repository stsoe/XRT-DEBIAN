Author: Mario Limonciello <superm1@gmail.com>
Forwarded: https://github.com/Xilinx/XRT/pull/9672
Description: restore legacy uppercase DRM log helpers on newer kernels

Newer kernels no longer expose the legacy uppercase DRM logging macros.
The XOCL and ZOCL driver trees still use them heavily, so provide local
fallback definitions that map to the generic pr_* helpers when needed.

Index: xrt/xrt/XRT/src/runtime_src/core/pcie/driver/linux/xocl/xocl_drv.h
===================================================================
--- xrt.orig/xrt/XRT/src/runtime_src/core/pcie/driver/linux/xocl/xocl_drv.h
+++ xrt/xrt/XRT/src/runtime_src/core/pcie/driver/linux/xocl/xocl_drv.h
@@ -35,6 +35,7 @@
 #endif
 #include <drm/drm_gem.h>
 #include <drm/drm_mm.h>
+#include <linux/printk.h>
 #include <linux/interrupt.h>
 #include <linux/poll.h>
 #include <linux/platform_device.h>
@@ -89,6 +90,31 @@
 
 #if LINUX_VERSION_CODE >= KERNEL_VERSION(5, 6, 0)
 #define ioremap_nocache		ioremap
+
+/*
+ * Legacy uppercase DRM logging helpers were dropped from newer kernels.
+ * Keep the existing call sites working by mapping them to the generic
+ * printk-based helpers when the DRM headers no longer provide them.
+ */
+#ifndef DRM_ERROR
+# define DRM_ERROR(fmt, ...) pr_err(fmt, ##__VA_ARGS__)
+#endif
+
+#ifndef DRM_WARN
+# define DRM_WARN(fmt, ...) pr_warn(fmt, ##__VA_ARGS__)
+#endif
+
+#ifndef DRM_INFO
+# define DRM_INFO(fmt, ...) pr_info(fmt, ##__VA_ARGS__)
+#endif
+
+#ifndef DRM_DEBUG
+# define DRM_DEBUG(fmt, ...) pr_debug(fmt, ##__VA_ARGS__)
+#endif
+
+#ifndef DRM_WARN_ONCE
+# define DRM_WARN_ONCE(fmt, ...) pr_warn_once(fmt, ##__VA_ARGS__)
+#endif
 #endif
 
 #ifndef mmiowb
